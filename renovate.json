{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits",
    "helpers:pinGitHubActionDigests"
  ],
  "timezone": "America/New_York",
  "schedule": ["before 6am on monday"],
  "prConcurrentLimit": 6,
  "prHourlyLimit": 3,
  "postUpdateOptions": ["gomodTidy"],
  "packageRules": [
    {
      "description": "Group all GitHub Actions bumps into one PR",
      "matchManagers": ["github-actions"],
      "groupName": "github-actions"
    },
    {
      "description": "cloud.google.com/go modules release together — batch them",
      "matchManagers": ["gomod"],
      "matchPackageNames": ["cloud.google.com/go/**"],
      "groupName": "google-cloud-go"
    },
    {
      "description": "Keep the templ binary pin in sync with the go.mod version",
      "matchDepNames": ["github.com/a-h/templ", "github.com/a-h/templ/cmd/templ"],
      "groupName": "templ"
    },
    {
      "description": "Batch non-major Go dependency updates",
      "matchManagers": ["gomod"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "go dependencies (non-major)"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Tailwind standalone CLI (Makefile var + Dockerfile ARG)",
      "managerFilePatterns": ["/^Makefile$/", "/^Dockerfile$/"],
      "matchStrings": [
        "TAILWIND_VERSION\\s*:?=\\s*(?<currentValue>v[\\d.]+)"
      ],
      "depNameTemplate": "tailwindlabs/tailwindcss",
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "description": "Cloud SQL Auth Proxy (Makefile var)",
      "managerFilePatterns": ["/^Makefile$/"],
      "matchStrings": [
        "SQL_PROXY_VERSION\\s*:?=\\s*(?<currentValue>v[\\d.]+)"
      ],
      "depNameTemplate": "GoogleCloudPlatform/cloud-sql-proxy",
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "description": "templ binary pinned in the Dockerfile go install and Makefile var",
      "managerFilePatterns": ["/^Dockerfile$/", "/^Makefile$/"],
      "matchStrings": [
        "github\\.com/a-h/templ/cmd/templ@(?<currentValue>v[\\d.]+)",
        "TEMPL_VERSION\\s*:?=\\s*(?<currentValue>v[\\d.]+)"
      ],
      "depNameTemplate": "github.com/a-h/templ",
      "datasourceTemplate": "go"
    },
    {
      "customType": "regex",
      "description": "golangci-lint binary version in the CI workflow",
      "managerFilePatterns": ["/^\\.github/workflows/test\\.yml$/"],
      "matchStrings": [
        "golangci-lint-action[\\s\\S]*?version:\\s*(?<currentValue>v[\\d.]+)"
      ],
      "depNameTemplate": "golangci/golangci-lint",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.*)$"
    },
    {
      "customType": "regex",
      "description": "Go toolchain version pinned in setup-go steps",
      "managerFilePatterns": ["/^\\.github/workflows/.+\\.yml$/"],
      "matchStrings": [
        "go-version:\\s*\"(?<currentValue>[\\d.]+)\""
      ],
      "depNameTemplate": "go",
      "datasourceTemplate": "golang-version",
      "versioningTemplate": "npm"
    }
  ]
}
